#!/bin/sh
set -eu

case "$(uname -m)" in
  x86_64|amd64) ;;
  *)
    echo "Teach currently supports Linux x86_64." >&2
    exit 64
    ;;
esac

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
archive="$script_dir/teach-mcp-linux-x64.gz"
cache_root=${XDG_CACHE_HOME:-"${HOME:?HOME is required}/.cache"}/teach/runtime
runtime="$cache_root/teach-mcp-0.2.0-r4"

umask 077
mkdir -p "$cache_root"

if [ ! -x "$runtime" ]; then
  temporary="$runtime.$$.tmp"
  trap 'test ! -e "$temporary" || unlink "$temporary"' EXIT HUP INT TERM
  gzip -dc "$archive" > "$temporary"
  chmod 0700 "$temporary"
  mv "$temporary" "$runtime"
  trap - EXIT HUP INT TERM
fi

exec "$runtime" "$@"
