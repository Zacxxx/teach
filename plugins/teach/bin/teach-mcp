#!/bin/sh
set -eu

system=$(uname -s)
machine=$(uname -m)
case "$system:$machine" in
  Linux:x86_64|Linux:amd64) platform=linux-x64 ;;
  Linux:aarch64|Linux:arm64) platform=linux-arm64 ;;
  Darwin:x86_64|Darwin:amd64) platform=darwin-x64 ;;
  Darwin:arm64|Darwin:aarch64) platform=darwin-arm64 ;;
  *)
    echo "Teach does not include a runtime for $system/$machine." >&2
    exit 64
    ;;
esac

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
archive="$script_dir/teach-mcp-$platform.gz"
if [ "$system" = Darwin ]; then
  cache_root="${HOME:?HOME is required}/Library/Caches/Teach/runtime"
else
  cache_root=${XDG_CACHE_HOME:-"${HOME:?HOME is required}/.cache"}/teach/runtime
fi
runtime="$cache_root/teach-mcp-0.3.0-r3-$platform"

umask 077
mkdir -p "$cache_root"

if [ ! -x "$runtime" ]; then
  temporary="$runtime.$$.tmp"
  trap 'test ! -e "$temporary" || unlink "$temporary"' EXIT HUP INT TERM
  gzip -dc "$archive" > "$temporary"
  chmod 0700 "$temporary"
  mv "$temporary" "$runtime"
  trap - EXIT HUP INT TERM
fi

exec "$runtime" "$@"
