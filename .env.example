# Keep the service loopback-only. This directory contains recordings and generated skills.
TEACH_GPT_HOME=$HOME/.local/share/teach-gpt
TEACH_GPT_MODEL=gpt-5.6
TEACH_GPT_ANALYZER=codex
TEACH_GPT_RECORDER=auto

# Override for development or judge-safe synthetic demos.
# TEACH_GPT_ANALYZER=fixture
# TEACH_GPT_RECORDER=demo
# TEACH_GPT_SKILLS_HOME=/tmp/teach-gpt-skills

