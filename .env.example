# Keep the service loopback-only. This directory contains recordings and generated skills.
TEACH_HOME=$HOME/.local/share/teach
TEACH_MODEL=gpt-5.6
TEACH_ANALYZER=codex
TEACH_RECORDER=auto

# Override for development or judge-safe synthetic demos.
# TEACH_ANALYZER=fixture
# TEACH_RECORDER=demo
# TEACH_SKILLS_HOME=/tmp/teach-skills

