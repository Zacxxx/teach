{
  "name": "@teach/mcp",
  "version": "0.3.0",
  "description": "Local MCP interface for Teach",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "bundle": "bun build src/index.ts --target=bun --minify --outfile ../../plugins/teach/bin/teach-mcp.js",
    "bundle:plugin": "bun run scripts/package-plugin.ts",
    "lint": "eslint src",
    "start": "bun run src/index.ts",
    "test": "bun test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "1.7.4",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@teach/core": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@types/node": "24.13.3",
    "eslint": "9.39.5",
    "typescript-eslint": "8.64.0",
    "typescript": "5.9.3"
  }
}
