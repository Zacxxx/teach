{
  "name": "@teach-gpt/mcp",
  "version": "0.1.0",
  "description": "Local MCP interface for Teach GPT",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "bundle": "bun build src/index.ts --target=bun --minify --outfile ../../plugins/teach-gpt/bin/teach-gpt-mcp.js",
    "lint": "eslint src",
    "start": "bun run src/index.ts",
    "test": "bun test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@teach-gpt/core": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@types/node": "24.13.3",
    "eslint": "9.39.5",
    "typescript-eslint": "8.64.0",
    "typescript": "5.9.3"
  }
}
