{
  "name": "teach",
  "version": "0.3.0",
  "private": true,
  "description": "Open-source cross-platform demonstrated-workflow learning for Codex",
  "license": "Apache-2.0",
  "packageManager": "bun@1.3.3",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "check": "bun run test && bun run typecheck && bun run lint && bun run build",
    "demo": "bun run --cwd packages/core demo",
    "dev": "bun run --cwd apps/web dev -- --hostname 127.0.0.1 --port 3141",
    "eval": "bun run --cwd packages/evals contract",
    "eval:live": "bun run --cwd packages/evals live",
    "lint": "bun run --filter '*' lint",
    "mcp": "bun run --cwd packages/mcp start",
    "test": "bun run --filter '*' test",
    "typecheck": "bun run --filter '*' typecheck",
    "video": "bun run scripts/build-demo-video.ts",
    "video:capture": "bun run scripts/capture-live-demo.ts"
  }
}
